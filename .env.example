# App — set to your live origin in production (auth redirects + Supabase email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Auth + Postgres + Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM — Groq is primary (required for best experience). Anthropic is optional fallback.
GROQ_API_KEY=your-groq-key
# Optional: llama-3.3-70b-versatile (default), mixtral-8x7b-32768, etc.
GROQ_MODEL=
# Optional fallback if GROQ_API_KEY is unset (leave empty if unused — do not use "KEY=" with no value if your tooling sends empty strings)
ANTHROPIC_API_KEY=

# Email (Resend) — optional; without it, drafts still generate but email is not delivered
RESEND_API_KEY=
RESEND_FROM_EMAIL=AgentForge <onboarding@resend.dev>

# Optional: webhook verification secret for inbound integrations
WEBHOOK_SECRET=

# Prompt 45 — Live web research (optional; research still works without)
# Tavily: https://tavily.com — preferred when set
TAVILY_API_KEY=
# Serper: https://serper.dev — used if Tavily returns nothing or is unset
SERPER_API_KEY=
# Browserless: rendered HTML for homepage, careers, about, blog (set both; Prompt 50 multi-page)
BROWSERLESS_BASE_URL=
BROWSERLESS_TOKEN=
